{
	"build": {
		"beforeBuildCommand": "bun run build",
		"beforeDevCommand": "bun run dev:web",
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420"
	},
	"bundle": {
		"active": true,
		"category": "Productivity",
		"publisher": "Irfan",
		"copyright": "Copyright \u00a9 2026 Irfan",
		"homepage": "https://mynah.site",
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"longDescription": "Local-first speech-to-text for your Mac. Uses local transcription engines, local diagnostics, and explicit user-started model downloads. No cloud transcription, no cloud rewrite, and no remote analytics.",
		"shortDescription": "Press shortcut \u2192 speak \u2192 get text. Local-only.",
		"createUpdaterArtifacts": false,
		"macOS": {
			"entitlements": "entitlements.plist",
			"hardenedRuntime": true,
			"minimumSystemVersion": "10.15",
			"signingIdentity": "Developer ID Application: Khalid Irfan (99YAK7YU3M)"
		},
		"linux": {
			"appimage": {
				"bundleMediaFramework": true
			}
		},
		"windows": {
			"webviewInstallMode": {
				"type": "embedBootstrapper"
			},
			"wix": {
				"fipsCompliant": true,
				"language": "en-US"
			},
			"nsis": {
				"compression": "bzip2",
				"installMode": "currentUser"
			}
		},
		"resources": [
			"icons/32x32.png",
			"recorder-state-icons/*"
		]
	},
	"productName": "Mynah",
	"version": "1.0.0",
	"identifier": "com.mynah.app",
	"app": {
		"macOSPrivateApi": true,
		"trayIcon": {
			"id": "mynah-tray",
			"iconPath": "icons/32x32.png",
			"tooltip": "Mynah — Ready",
			"menuOnLeftClick": false
		},
		"windows": [
			{
				"resizable": true,
				"title": "Mynah",
				"width": 500,
				"height": 720,
				"minHeight": 700,
				"minWidth": 460,
				"transparent": true,
				"decorations": true
			},
			{
				"label": "overlay",
				"title": "Mynah Overlay",
				"width": 240,
				"height": 80,
				"resizable": false,
				"decorations": false,
				"alwaysOnTop": true,
				"transparent": true,
				"visible": false,
				"skipTaskbar": true,
				"focusable": false
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": [
					"**"
				]
			}
		}
	}
}
