{
	"build": {
		"beforeBuildCommand": "bun run build",
		"beforeDevCommand": "bun run dev:web",
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420"
	},
	"bundle": {
		"active": true,
		"category": "Productivity",
		"publisher": "Irfan",
		"copyright": "Copyright \u00a9 2026 Irfan",
		"homepage": "https://github.com/teachme-ai/speakpaste",
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"longDescription": "Seamlessly integrate speech-to-text transcriptions anywhere on your desktop. Powered by OpenAI's Whisper API.",
		"shortDescription": "Press shortcut \u2192 speak \u2192 get text. Free.",
		"createUpdaterArtifacts": false,
		"macOS": {
			"entitlements": "entitlements.plist",
			"hardenedRuntime": true,
			"minimumSystemVersion": "10.15",
			"signingIdentity": null
		},
		"linux": {
			"appimage": {
				"bundleMediaFramework": true
			}
		},
		"windows": {
			"webviewInstallMode": {
				"type": "embedBootstrapper"
			},
			"wix": {
				"fipsCompliant": true,
				"language": "en-US"
			},
			"nsis": {
				"compression": "bzip2",
				"installMode": "currentUser"
			}
		},
		"resources": [
			"recorder-state-icons/*"
		]
	},
	"productName": "SpeakPaste",
	"version": "0.1.0",
	"identifier": "com.speakpaste.app",
	"plugins": {
		"updater": {
			"pubkey": "dW51c2VkX3BsYWNlaG9sZGVyX2tleV9mb3JfZGV2ZWxvcG1lbnRfcHVycG9zZXMK",
			"endpoints": [
				"https://raw.githubusercontent.com/teachme-ai/speakpaste/main/update.json"
			]
		}
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"resizable": true,
				"title": "SpeakPaste",
				"width": 500,
				"height": 850,
				"minHeight": 850,
				"minWidth": 460,
				"transparent": true,
				"decorations": true
			},
			{
				"label": "overlay",
				"title": "SpeakPaste Overlay",
				"width": 240,
				"height": 80,
				"resizable": false,
				"decorations": false,
				"alwaysOnTop": true,
				"transparent": true,
				"visible": false,
				"skipTaskbar": true
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": [
					"**"
				]
			}
		}
	}
}
