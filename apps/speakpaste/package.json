{
	"name": "mynah",
	"private": true,
	"version": "1.0.0",
	"description": "Mynah — Mac-only local-first voice typing powered by whisper.cpp.",
	"scripts": {
		"prepare:build-meta": "bun ./scripts/prepare-build-meta.mjs",
		"dev:web": "bun run prepare:build-meta && vite dev",
		"dev": "bun run tauri dev --config '{\"identifier\": \"com.mynah.app.dev\"}'",
		"build": "bun run prepare:build-meta && NODE_ENV=production bun --bun vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"tauri": "bun ./scripts/run-tauri-with-build-meta.mjs",
		"build:all": "bun ./scripts/build-both.mjs",
		"publish:website": "bun ./scripts/publish-to-website.mjs"
	},
	"license": "UNLICENSED",
	"devDependencies": {
		"@epicenter/ui": "workspace:*",
		"@types/bun": "catalog:",
		"@lucide/svelte": "catalog:",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tauri-apps/cli": "catalog:",
		"@types/dompurify": "^3.2.0",
		"@types/js-yaml": "^4.0.9",
		"mode-watcher": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"svelte-sonner": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"type": "module",
	"dependencies": {
		"@epicenter/constants": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@ricky0123/vad-web": "^0.0.24",
		"@standard-schema/spec": "catalog:",
		"@tanstack/svelte-query": "catalog:",
		"@tanstack/svelte-query-devtools": "catalog:",
		"@tanstack/svelte-table": "catalog:",
		"@tanstack/table-core": "9.0.0-alpha.10",
		"@tauri-apps/api": "catalog:",
		"@tauri-apps/plugin-autostart": "^2.0.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.0",
		"@tauri-apps/plugin-dialog": "^2.3.2",
		"@tauri-apps/plugin-fs": "catalog:",
		"@tauri-apps/plugin-global-shortcut": "^2.3.0",
		"@tauri-apps/plugin-http": "^2.5.1",
		"@tauri-apps/plugin-log": "~2",
		"@tauri-apps/plugin-notification": "^2.3.0",
		"@tauri-apps/plugin-opener": "catalog:",
		"@tauri-apps/plugin-os": "^2.3.0",
		"@tauri-apps/plugin-process": "^2.3.0",
		"@tauri-apps/plugin-shell": "^2.3.0",
		"arkregex": "catalog:",
		"arktype": "catalog:",
		"audio-recorder-polyfill": "^0.4.1",
		"bits-ui": "catalog:",
		"date-fns": "catalog:",
