{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "mynah",
	"compatibility_date": "2025-11-04",
	"assets": {
		"directory": "build",
		"not_found_handling": "single-page-application"
	},
	// Enable preview URLs for PR previews via `wrangler versions upload --preview-alias`
	"preview_urls": true,
	"observability": {
		"enabled": true
	}
}
